---
import type { ProjectsContent } from '../../data/portfolio';

interface Props {
	section: ProjectsContent;
}

const { section } = Astro.props;
---

<section id={section.id} class="section-shell section-shell--projects">
	<div class="section-heading">
		<p class="eyebrow">{section.label}</p>
		<h2>{section.title}</h2>
		<p class="section-intro">{section.intro}</p>
	</div>

	<div class="project-grid">
		{
			section.items.map((project, index) => (
				<article class="surface-card project-card">
					<div class="project-card__media">
						<img
							src={project.imageSrc}
							alt={project.imageAlt}
							width="1200"
							height="720"
							loading="lazy"
						/>
					</div>
					<div class="project-card__meta">
						<p>{String(index + 1).padStart(2, '0')}</p>
						<span>{project.category}</span>
					</div>
					<h3>{project.name}</h3>
					<p class="project-summary">{project.summary}</p>
					<ul class="project-highlights">
						{
							project.highlights.map((item) => (
								<li>{item}</li>
							))
						}
					</ul>
					<ul class="chip-list">
						{
							project.stack.map((item) => (
								<li class="chip">{item}</li>
							))
						}
					</ul>
					<a
						class="button button--secondary"
						href={project.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={`${project.cta}: ${project.name}`}
					>
						{project.cta}
					</a>
				</article>
			))
		}
	</div>
</section>

<style>
	.section-shell--projects {
		padding: clamp(1.3rem, 3vw, 2.2rem);
		animation: rise-in 0.7s ease 0.08s both;
	}

	.section-heading h2 {
		margin: 0.8rem 0 0;
		font-size: clamp(1.95rem, 4vw, 3rem);
		line-height: 1.05;
		letter-spacing: -0.04em;
	}

	.section-intro {
		max-width: 62ch;
		margin: 1rem 0 0;
		line-height: 1.75;
		color: var(--text-muted);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.75rem;
	}

	.project-card {
		position: relative;
		overflow: hidden;
		display: grid;
		gap: 1rem;
		align-content: start;
		padding: 1.2rem;
		transition:
			transform 0.24s ease,
			border-color 0.24s ease,
			background-color 0.24s ease,
			box-shadow 0.24s ease;
	}

	.project-card:hover,
	.project-card:focus-within {
		transform: translateY(-4px);
		border-color: rgba(112, 245, 255, 0.22);
		background: rgba(255, 255, 255, 0.05);
		box-shadow: 0 28px 80px rgba(0, 0, 0, 0.32);
	}

	.project-card__media {
		position: relative;
		aspect-ratio: 5 / 3;
		border-radius: 1rem;
		border: 1px solid rgba(112, 245, 255, 0.12);
		overflow: hidden;
	}

	.project-card__media::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 20%),
			linear-gradient(0deg, rgba(4, 7, 11, 0.35), transparent 45%);
		pointer-events: none;
	}

	.project-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.28s ease;
	}

	.project-card:hover .project-card__media img,
	.project-card:focus-within .project-card__media img {
		transform: scale(1.025);
	}

	.project-card__meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: 0.84rem;
		color: var(--accent-warm);
	}

	.project-card__meta p,
	.project-card__meta span,
	.project-card h3,
	.project-summary {
		margin: 0;
	}

	.project-card h3 {
		font-size: 1.4rem;
		line-height: 1.2;
	}

	.project-summary {
		line-height: 1.75;
		color: var(--text-muted);
	}

	.project-highlights {
		list-style: none;
		padding: 0;
		margin: -0.1rem 0 0;
		display: grid;
		gap: 0.45rem;
	}

	.project-highlights li {
		position: relative;
		padding-left: 1rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.project-highlights li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.62rem;
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 12px rgba(112, 245, 255, 0.32);
	}

	.project-card .button {
		justify-self: start;
		margin-top: 0.25rem;
	}

	@media (max-width: 860px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.section-shell--projects {
			padding: 1.05rem;
		}

		.section-heading h2 {
			font-size: 1.7rem;
		}

		.section-intro {
			font-size: 0.96rem;
			line-height: 1.68;
		}

		.project-grid {
			gap: 0.85rem;
			margin-top: 1.35rem;
		}

		.project-card {
			padding: 1rem;
			gap: 0.85rem;
		}

		.project-card__media {
			border-radius: 0.85rem;
		}

		.project-card__meta {
			font-size: 0.78rem;
		}

		.project-card h3 {
			font-size: 1.18rem;
		}

		.project-summary,
		.project-highlights li {
			line-height: 1.62;
		}

		.project-card .button {
			justify-self: stretch;
		}
	}

	@media (max-width: 420px) {
		.project-card__meta {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.3rem;
		}

		.project-highlights {
			gap: 0.4rem;
		}
	}
</style>