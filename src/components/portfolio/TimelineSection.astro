---
import type { TimelineContent } from '../../data/portfolio';

interface Props {
	section: TimelineContent;
}

const { section } = Astro.props;
---

<section id={section.id} class="section-shell section-shell--timeline">
	<div class="section-heading">
		<p class="eyebrow">{section.label}</p>
		<h2>{section.title}</h2>
		<p class="section-intro">{section.intro}</p>
	</div>

	<ol class="timeline-list">
		{
			section.items.map((item, index) => (
				<li class="timeline-item">
					<span class="timeline-marker" aria-hidden="true"></span>
					<article class="surface-card timeline-card">
						<div class="timeline-card__meta">
							<p class="timeline-period">{item.period}</p>
							<span class="timeline-index">{String(index + 1).padStart(2, '0')}</span>
						</div>
						<h3>{item.title}</h3>
						<p>{item.summary}</p>
					</article>
				</li>
			))
		}
	</ol>
</section>

<style>
	.section-shell--timeline {
		padding: clamp(1.3rem, 3vw, 2.2rem);
		animation: rise-in 0.7s ease both;
	}

	.section-heading {
		max-width: 48rem;
	}

	.section-heading h2 {
		margin: 0.8rem 0 0;
		font-size: clamp(1.95rem, 4vw, 3rem);
		line-height: 1.05;
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	.section-intro {
		margin: 1rem 0 0;
		font-size: 1rem;
		line-height: 1.75;
		color: var(--text-muted);
	}

	.timeline-list {
		position: relative;
		list-style: none;
		padding: 0;
		margin: 1.75rem 0 0;
		display: grid;
		gap: 1rem;
	}

	.timeline-list::before {
		content: '';
		position: absolute;
		left: 1rem;
		top: 0.7rem;
		bottom: 0.7rem;
		width: 1px;
		background: linear-gradient(180deg, rgba(112, 245, 255, 0.42), rgba(255, 82, 146, 0.18));
	}

	.timeline-item {
		position: relative;
		padding-left: 3rem;
	}

	.timeline-marker {
		position: absolute;
		left: 0.55rem;
		top: 1.35rem;
		width: 0.9rem;
		height: 0.9rem;
		border-radius: 50%;
		background: var(--accent);
		box-shadow:
			0 0 0 5px rgba(112, 245, 255, 0.14),
			0 0 18px rgba(112, 245, 255, 0.35);
	}

	.timeline-card {
		position: relative;
		overflow: hidden;
		padding: 1.15rem 1.2rem 1.25rem;
		transition:
			transform 0.24s ease,
			border-color 0.24s ease,
			background-color 0.24s ease;
	}

	.timeline-card::before {
		content: '';
		position: absolute;
		inset: 0 auto 0 0;
		width: 3px;
		background: linear-gradient(180deg, var(--accent), rgba(255, 82, 146, 0.55));
		opacity: 0.9;
	}

	.timeline-item:nth-child(even) .timeline-card {
		transform: translateX(0.55rem);
	}

	.timeline-item:hover .timeline-card,
	.timeline-item:focus-within .timeline-card {
		transform: translateX(0) translateY(-2px);
		border-color: rgba(112, 245, 255, 0.22);
		background: rgba(255, 255, 255, 0.05);
	}

	.timeline-card__meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.timeline-period {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.88rem;
		color: var(--accent-warm);
	}

	.timeline-index {
		font-family: var(--font-display);
		font-size: 0.56rem;
		color: var(--text-muted);
	}

	.timeline-card h3 {
		margin: 0.7rem 0 0;
		font-size: 1.24rem;
		line-height: 1.25;
	}

	.timeline-card p:last-child {
		margin: 0.9rem 0 0;
		line-height: 1.75;
		color: var(--text-muted);
	}

	@media (max-width: 640px) {
		.section-shell--timeline {
			padding: 1.05rem;
		}

		.section-heading h2 {
			font-size: 1.7rem;
		}

		.section-intro {
			font-size: 0.96rem;
			line-height: 1.68;
		}

		.timeline-list::before {
			left: 0.75rem;
		}

		.timeline-item {
			padding-left: 2rem;
		}

		.timeline-marker {
			left: 0.28rem;
			top: 1.15rem;
			width: 0.82rem;
			height: 0.82rem;
		}

		.timeline-card {
			padding: 1rem 1rem 1.05rem;
		}

		.timeline-card h3 {
			font-size: 1.08rem;
		}

		.timeline-card p:last-child {
			line-height: 1.66;
		}

		.timeline-item:nth-child(even) .timeline-card {
			transform: none;
		}
	}

	@media (max-width: 420px) {
		.timeline-card__meta {
			gap: 0.6rem;
		}

		.timeline-index {
			font-size: 0.5rem;
		}
	}
</style>