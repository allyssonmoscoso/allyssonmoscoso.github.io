---
import type { PageContent } from '../../data/portfolio';

interface Props {
	brand: string;
	brandTag: string;
	navigation: PageContent['navigation'];
	localeLinks: Array<{
		href: string;
		label: string;
		isActive: boolean;
	}>;
}

const { brand, brandTag, navigation, localeLinks } = Astro.props;
---

<header class="site-header">
	<div class="site-header__frame">
		<a class="brand" href="#about" aria-label={brand}>
			<span class="brand__mark" aria-hidden="true">AM</span>
			<span class="brand__copy">
				<strong>{brand}</strong>
				<small>{brandTag}</small>
			</span>
		</a>

		<nav class="desktop-nav" aria-label={navigation.label}>
			<ul>
				{
					navigation.items.map((item) => (
						<li>
							<a href={`#${item.id}`}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="site-header__actions">
			<div class="locale-switcher" aria-label={navigation.localeLabel}>
				{
					localeLinks.map((link) => (
						<a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
							{link.label}
						</a>
					))
				}
			</div>

			<details class="mobile-nav">
				<summary aria-label={navigation.menuButtonLabel}>
					<span></span>
					<span></span>
					<span></span>
				</summary>
				<nav aria-label={navigation.label}>
					<ul>
						{
							navigation.items.map((item) => (
								<li>
									<a href={`#${item.id}`}>{item.label}</a>
								</li>
							))
						}
					</ul>
				</nav>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0.75rem;
		backdrop-filter: blur(16px);
	}

	.site-header__frame {
		position: relative;
		overflow: hidden;
		width: min(var(--container), calc(100vw - 2rem));
		margin: 0 auto;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.8rem 1rem;
		border: 1px solid rgba(112, 245, 255, 0.18);
		border-radius: 999px;
		background: rgba(4, 9, 15, 0.82);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
		animation: rise-in 0.7s ease both;
	}

	.site-header__frame::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		padding: 1px;
		background: linear-gradient(120deg, rgba(112, 245, 255, 0.18), rgba(255, 82, 146, 0.12), rgba(112, 245, 255, 0.08));
		mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		mask-composite: xor;
		-webkit-mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		pointer-events: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
	}

	.brand__mark {
		display: grid;
		place-items: center;
		width: 2.7rem;
		height: 2.7rem;
		border-radius: 0.9rem;
		border: 1px solid rgba(255, 82, 146, 0.35);
		background:
			radial-gradient(circle at top, rgba(255, 82, 146, 0.35), transparent 60%),
			rgba(255, 255, 255, 0.03);
		font-family: var(--font-display);
		font-size: 0.72rem;
		color: var(--text);
	}

	.brand__copy {
		min-width: 0;
	}

	.brand__copy strong,
	.brand__copy small {
		display: block;
	}

	.brand__copy strong {
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.brand__copy small {
		margin-top: 0.2rem;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.desktop-nav ul,
	.mobile-nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.desktop-nav ul {
		display: flex;
		justify-content: center;
		gap: 0.25rem;
	}

	.desktop-nav a,
	.mobile-nav a {
		display: block;
		padding: 0.7rem 0.95rem;
		border-radius: 999px;
		color: var(--text-muted);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.desktop-nav a:hover,
	.desktop-nav a:focus-visible,
	.mobile-nav a:hover,
	.mobile-nav a:focus-visible {
		background: rgba(255, 255, 255, 0.06);
		color: var(--text);
		transform: translateY(-1px);
	}

	.site-header__actions {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
	}

	.locale-switcher {
		display: inline-flex;
		padding: 0.22rem;
		border-radius: 999px;
		border: 1px solid rgba(112, 245, 255, 0.16);
		background: rgba(255, 255, 255, 0.03);
	}

	.locale-switcher a {
		padding: 0.55rem 0.78rem;
		border-radius: 999px;
		font-family: var(--font-display);
		font-size: 0.62rem;
		color: var(--text-muted);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.locale-switcher a[aria-current='page'] {
		background: var(--accent);
		color: #041017;
		box-shadow: 0 12px 28px rgba(112, 245, 255, 0.22);
	}

	.locale-switcher a:not([aria-current='page']):hover,
	.locale-switcher a:not([aria-current='page']):focus-visible {
		background: rgba(112, 245, 255, 0.08);
		color: var(--text);
	}

	.mobile-nav {
		display: none;
		position: relative;
	}

	.mobile-nav summary {
		list-style: none;
		cursor: pointer;
		display: grid;
		place-items: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: 999px;
		border: 1px solid rgba(112, 245, 255, 0.18);
		background: rgba(255, 255, 255, 0.03);
	}

	.mobile-nav summary::-webkit-details-marker {
		display: none;
	}

	.mobile-nav summary span {
		display: block;
		width: 1rem;
		height: 2px;
		border-radius: 999px;
		background: var(--text);
	}

	.mobile-nav summary span + span {
		margin-top: 0.22rem;
	}

	.mobile-nav[open] nav {
		position: absolute;
		top: calc(100% + 0.75rem);
		right: 0;
		width: min(20rem, calc(100vw - 2rem));
		padding: 0.75rem;
		border-radius: 1.2rem;
		border: 1px solid rgba(112, 245, 255, 0.18);
		background: rgba(4, 9, 15, 0.96);
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
	}

	.mobile-nav ul {
		display: grid;
		gap: 0.3rem;
	}

	.mobile-nav a {
		padding: 0.85rem 1rem;
		border-radius: 0.95rem;
	}

	@media (max-width: 900px) {
		.site-header__frame {
			grid-template-columns: 1fr auto;
			border-radius: 1.7rem;
		}

		.desktop-nav {
			display: none;
		}

		.mobile-nav {
			display: block;
		}
	}

	@media (max-width: 620px) {
		.site-header__frame {
			width: calc(100vw - 1rem);
			padding: 0.65rem 0.7rem;
			gap: 0.55rem;
		}

		.brand__copy small {
			display: none;
		}

		.brand {
			gap: 0.65rem;
		}

		.brand__mark {
			width: 2.35rem;
			height: 2.35rem;
			border-radius: 0.72rem;
			font-size: 0.64rem;
		}

		.brand__copy strong {
			font-size: 0.84rem;
		}

		.site-header__actions {
			gap: 0.5rem;
		}

		.locale-switcher a {
			padding: 0.5rem 0.62rem;
			font-size: 0.56rem;
		}

		.mobile-nav summary {
			width: 2.55rem;
			height: 2.55rem;
		}
	}

	@media (max-width: 460px) {
		.site-header {
			padding-top: 0.65rem;
		}

		.site-header__frame {
			grid-template-columns: 1fr auto;
			border-radius: 1.15rem;
		}

		.mobile-nav[open] nav {
			left: 0;
			right: 0;
			width: auto;
			margin-top: 0.15rem;
		}

		.mobile-nav a {
			padding: 0.95rem 1rem;
		}

		.locale-switcher {
			padding: 0.18rem;
		}
	}
</style>