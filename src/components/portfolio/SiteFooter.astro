---
import type { FooterContent } from '../../data/portfolio';

interface Props {
	content: FooterContent;
}

const { content } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer__frame surface-card">
		<div>
			<p class="site-footer__copy">© {year} Allysson Moscoso. {content.copy}</p>
			<p class="site-footer__note">{content.builtWith}</p>
		</div>
		<a href={content.githubHref} target="_blank" rel="noopener noreferrer">
			{content.githubLabel}
		</a>
	</div>
</footer>

<style>
	.site-footer {
		padding: 0 0 2rem;
	}

	.site-footer__frame {
		width: min(var(--container), calc(100vw - 2rem));
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1.2rem 1.3rem;
	}

	.site-footer__copy,
	.site-footer__note {
		margin: 0;
	}

	.site-footer__copy {
		font-size: 0.98rem;
	}

	.site-footer__note {
		margin-top: 0.35rem;
		color: var(--text-muted);
		line-height: 1.6;
	}

	.site-footer a {
		flex-shrink: 0;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(112, 245, 255, 0.18);
		color: var(--text);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.site-footer a:hover,
	.site-footer a:focus-visible {
		background: rgba(112, 245, 255, 0.1);
		color: var(--accent);
		transform: translateY(-1px);
	}

	@media (max-width: 720px) {
		.site-footer__frame {
			flex-direction: column;
			align-items: flex-start;
			padding: 1rem;
		}

		.site-footer a {
			width: 100%;
			justify-content: center;
		}
	}

	@media (max-width: 420px) {
		.site-footer__frame {
			width: calc(100vw - 1rem);
		}

		.site-footer__copy,
		.site-footer__note {
			font-size: 0.92rem;
		}
	}
</style>